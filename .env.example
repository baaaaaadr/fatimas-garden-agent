# ---- Google Gemini (AI Studio) ----
# FREE tier works (no billing). Create a key: https://aistudio.google.com/apikey
# Copy this file to .env and paste your real key. NEVER commit the real .env.
GEMINI_API_KEY=your_key_here

# ---- Models (verified IDs, June 2026) ----
# Override anytime. If the free tier doesn't cover 3.5-flash, switch to gemini-3.1-flash-lite.
GEMINI_MODEL=gemini-3.5-flash
GEMINI_MODEL_LITE=gemini-3.1-flash-lite
